# Required for intake, generation, visual critique, and revision.
OPENAI_API_KEY=

# Optional. Without these values Mainstreet serves the finished site locally.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional text and vision model override.
OPENAI_MODEL=gpt-5.6

# Optional image model override.
OPENAI_IMAGE_MODEL=gpt-image-1
