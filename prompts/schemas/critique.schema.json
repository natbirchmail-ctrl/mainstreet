{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "rubricVersion": { "type": "string", "enum": ["1.0"] },
    "summary": { "type": "string" },
    "dimensions": {
      "type": "object",
      "properties": {
        "layout": { "$ref": "#/$defs/dimension" },
        "hierarchy": { "$ref": "#/$defs/dimension" },
        "color": { "$ref": "#/$defs/dimension" },
        "typography": { "$ref": "#/$defs/dimension" },
        "mobile": { "$ref": "#/$defs/dimension" },
        "specificity": { "$ref": "#/$defs/dimension" },
        "accessibility": { "$ref": "#/$defs/dimension" },
        "polish": { "$ref": "#/$defs/dimension" }
      },
      "required": ["layout", "hierarchy", "color", "typography", "mobile", "specificity", "accessibility", "polish"],
      "additionalProperties": false
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 5
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "priority": { "type": "integer", "minimum": 1, "maximum": 10 },
          "severity": { "type": "string", "enum": ["major", "medium", "minor"] },
          "dimension": { "type": "string", "enum": ["layout", "hierarchy", "color", "typography", "mobile", "specificity", "accessibility", "polish"] },
          "evidence": { "type": "string" },
          "impact": { "type": "string" },
          "fix": { "type": "string" }
        },
        "required": ["priority", "severity", "dimension", "evidence", "impact", "fix"],
        "additionalProperties": false
      },
      "maxItems": 10
    },
    "laws": {
      "type": "object",
      "properties": {
        "headlineDiscipline": { "$ref": "#/$defs/law" },
        "foldComposition": { "$ref": "#/$defs/law" },
        "completeLayouts": { "$ref": "#/$defs/law" },
        "firstBeatVisibility": { "$ref": "#/$defs/law" },
        "imageContrast": { "$ref": "#/$defs/law" },
        "motionRestraint": { "$ref": "#/$defs/law" },
        "imageryCoherence": { "$ref": "#/$defs/law" },
        "factualRestraint": { "$ref": "#/$defs/law" }
      },
      "required": [
        "headlineDiscipline",
        "foldComposition",
        "completeLayouts",
        "firstBeatVisibility",
        "imageContrast",
        "motionRestraint",
        "imageryCoherence",
        "factualRestraint"
      ],
      "additionalProperties": false
    },
    "revisionBrief": {
      "type": "object",
      "properties": {
        "mustFix": { "type": "array", "items": { "type": "string" }, "maxItems": 6 },
        "preserve": { "type": "array", "items": { "type": "string" }, "maxItems": 6 }
      },
      "required": ["mustFix", "preserve"],
      "additionalProperties": false
    }
  },
  "required": ["rubricVersion", "summary", "dimensions", "strengths", "issues", "laws", "revisionBrief"],
  "additionalProperties": false,
  "$defs": {
    "dimension": {
      "type": "object",
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 18 },
        "evidence": { "type": "string" },
        "fix": { "type": "string" }
      },
      "required": ["score", "evidence", "fix"],
      "additionalProperties": false
    },
    "law": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail", "unverified"] },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/lawEvidence" },
          "minItems": 1,
          "maxItems": 6
        },
        "fix": { "type": "string" }
      },
      "required": ["status", "evidence", "fix"],
      "additionalProperties": false
    },
    "lawEvidence": {
      "type": "object",
      "properties": {
        "viewport": {
          "type": "string",
          "enum": ["desktop", "tablet", "phone", "source"]
        },
        "observation": { "type": "string" }
      },
      "required": ["viewport", "observation"],
      "additionalProperties": false
    }
  }
}
